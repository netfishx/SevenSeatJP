{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sevenseatjp",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "observability": { "enabled": true }
}
