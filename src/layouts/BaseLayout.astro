---
import LangSwitch from '@/components/ui/LangSwitch.astro';
import MobileMenu from '@/components/ui/MobileMenu.astro';
import SiteNav from '@/components/ui/SiteNav.astro';
import { type Locale, t } from '@/i18n/t';
import { getCanonicalUrl } from '@/lib/alternate';
import '@/styles/globals.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
}

const { locale, title, description, ogImage = '/og-default.png' } = Astro.props;
const fullTitle = title ? `${title} | ${t(locale, 'site.name')}` : t(locale, 'site.name');
const canonical = new URL(getCanonicalUrl(Astro.url, locale), Astro.site);
const jaUrl = new URL(getCanonicalUrl(Astro.url, 'ja'), Astro.site);
const zhUrl = new URL(getCanonicalUrl(Astro.url, 'zh'), Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const ogLocale = locale === 'zh' ? 'zh_CN' : 'ja_JP';
const ogLocaleAlt = locale === 'zh' ? 'ja_JP' : 'zh_CN';
const desc = description ?? t(locale, 'site.name');
const homeHref = locale === 'zh' ? '/zh/' : '/';
const legalPrefix = locale === 'zh' ? '/zh' : '';
---
<!doctype html>
<html lang={locale === 'ja' ? 'ja' : 'zh-CN'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ja" href={jaUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={jaUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t(locale, 'site.name')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script>
      import '@/lib/attribution.client';
    </script>
  </head>
  <body class="min-h-screen bg-bg text-text font-body flex flex-col">
    <header class="sticky top-0 z-30 backdrop-blur-md bg-bg/85 border-b border-border flex justify-center">
      <div class="w-full max-w-7xl flex items-center gap-4 px-6 py-4">
        <a
          href={homeHref}
          class="font-display text-xl text-gold whitespace-nowrap"
        >{t(locale, 'site.name')}</a>
        <div class="flex-1 flex justify-center">
          <SiteNav locale={locale} variant="header" />
        </div>
        <div class="flex items-center gap-2">
          <LangSwitch />
          <MobileMenu locale={locale} />
        </div>
      </div>
    </header>

    <main class="flex-1"><slot /></main>

    <footer class="border-t border-border flex justify-center">
      <div class="w-full max-w-7xl px-6 py-10 flex flex-col gap-8">
        <SiteNav locale={locale} variant="footer" />
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-border text-xs text-text-muted">
          <p>© {new Date().getFullYear()} SevenSeatJP</p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            <a
              href={`${legalPrefix}/legal/tokushoho`}
              class="inline-flex items-center min-h-11 hover:text-gold"
            >{t(locale, 'about.section.policy.tokushoho')}</a>
            <a
              href={`${legalPrefix}/legal/privacy`}
              class="inline-flex items-center min-h-11 hover:text-gold"
            >{t(locale, 'about.section.policy.privacy')}</a>
            <a
              href={`${legalPrefix}/legal/cancel-policy`}
              class="inline-flex items-center min-h-11 hover:text-gold"
            >{t(locale, 'about.section.policy.cancel')}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
