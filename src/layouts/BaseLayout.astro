---
import LangSwitch from '@/components/ui/LangSwitch.astro';
import MobileMenu from '@/components/ui/MobileMenu.astro';
import MobileMenuPanel from '@/components/ui/MobileMenuPanel.astro';
import SiteNav from '@/components/ui/SiteNav.astro';
import { type Locale, t } from '@/i18n/t';
import { getCanonicalUrl } from '@/lib/alternate';
import '@/styles/globals.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  /**
   * When `true`, the site header floats over the hero on initial paint and
   * gains its solid backdrop on scroll. Pages without an immersive hero
   * (legal, FAQ) should leave this `false` so the header is opaque from
   * the start.
   */
  immersiveHeader?: boolean;
}

const {
  locale,
  title,
  description,
  ogImage = '/og-default.png',
  immersiveHeader = false,
} = Astro.props;
const fullTitle = title ? `${title} | ${t(locale, 'site.name')}` : t(locale, 'site.name');
const canonical = new URL(getCanonicalUrl(Astro.url, locale), Astro.site);
const jaUrl = new URL(getCanonicalUrl(Astro.url, 'ja'), Astro.site);
const zhUrl = new URL(getCanonicalUrl(Astro.url, 'zh'), Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const ogLocale = locale === 'zh' ? 'zh_CN' : 'ja_JP';
const ogLocaleAlt = locale === 'zh' ? 'ja_JP' : 'zh_CN';
const desc = description ?? t(locale, 'site.name');
const homeHref = locale === 'zh' ? '/zh/' : '/';
const legalPrefix = locale === 'zh' ? '/zh' : '';
const year = new Date().getFullYear();
---
<!doctype html>
<html lang={locale === 'ja' ? 'ja' : 'zh-CN'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1c1a17" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ja" href={jaUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={jaUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t(locale, 'site.name')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:wght@300;400;600&family=Shippori+Mincho:wght@400;600&family=Zen+Kaku+Gothic+New:wght@300;400;500;700&display=swap"
    />

    <script>
      import '@/lib/attribution.client';
    </script>
  </head>
  <body class="min-h-screen flex flex-col gap-24 sm:gap-40 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:start-3 focus:z-50 focus:bg-bg focus:text-gold focus:px-3 focus:py-2"
    >Skip to content</a>

    <header
      data-site-header
      data-immersive={immersiveHeader ? 'true' : 'false'}
      class:list={[
        'fixed inset-x-0 top-0 z-40 transition-[background-color,backdrop-filter,border-color] duration-300',
        immersiveHeader
          ? 'bg-transparent border-b border-transparent'
          : 'bg-bg/85 backdrop-blur-md border-b border-border',
      ]}
    >
      <div class="flex justify-center">
        <div class="w-full max-w-7xl flex items-center gap-4 px-5 sm:px-8 py-5">
          <a
            href={homeHref}
            class="font-display text-base sm:text-lg text-text tracking-[0.18em] uppercase whitespace-nowrap"
          >Seven<span class="text-text-deep">·</span>Seat</a>
          <div class="flex-1 flex justify-center">
            <SiteNav locale={locale} variant="header" />
          </div>
          <div class="flex items-center gap-3">
            <LangSwitch />
            <MobileMenu locale={locale} />
          </div>
        </div>
      </div>
    </header>

    <MobileMenuPanel locale={locale} />

    <main
      id="main"
      class:list={[
        'flex-1 flex flex-col',
        !immersiveHeader && 'pt-24 sm:pt-28',
      ]}
    ><slot /></main>

    <footer class="flex justify-center">
      <div class="w-full max-w-7xl px-5 sm:px-8 pb-12 flex flex-col gap-12">
        <div class="border-t border-border pt-12 grid grid-cols-1 md:grid-cols-12 gap-8">
          <div class="md:col-span-4 flex flex-col gap-3">
            <p class="font-display text-xl tracking-[0.18em] uppercase">Seven<span class="text-text-deep">·</span>Seat</p>
            <p class="text-sm text-text-muted leading-relaxed max-w-xs">
              {locale === 'zh'
                ? '日本全境的私人专车手配。东京・京都・白马，双语司机随行。'
                : '日本全土のプライベートハイヤー手配。東京・京都・白馬、二言語ドライバー同行。'}
            </p>
          </div>

          <nav class="md:col-span-5" aria-label="Footer">
            <SiteNav locale={locale} variant="footer" />
          </nav>

          <div class="md:col-span-3 flex flex-col gap-2 text-sm text-text-muted">
            <p>LINE: <span class="text-text">@sevenseatjp</span></p>
            <p>WeChat: <span class="text-text">sevenseatjp</span></p>
            <p>Mail: <span class="text-text">contact@sevenseatjp.com</span></p>
          </div>
        </div>

        <div class="border-t border-border pt-6 flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4 text-xs text-text-muted">
          <p class="tabular">© {year} &nbsp; SevenSeatJP &nbsp;·&nbsp; All rights reserved</p>
          <div class="flex flex-wrap gap-x-6 gap-y-2">
            <a
              href={`${legalPrefix}/legal/tokushoho`}
              class="inline-flex items-center min-h-11 hover:text-text"
            >{t(locale, 'about.section.policy.tokushoho')}</a>
            <a
              href={`${legalPrefix}/legal/privacy`}
              class="inline-flex items-center min-h-11 hover:text-text"
            >{t(locale, 'about.section.policy.privacy')}</a>
            <a
              href={`${legalPrefix}/legal/cancel-policy`}
              class="inline-flex items-center min-h-11 hover:text-text"
            >{t(locale, 'about.section.policy.cancel')}</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Header tone shift: immersive header gets a solid backdrop only after
      // the user has scrolled past the hero fold.
      const header = document.querySelector<HTMLElement>('[data-site-header]');
      if (header && header.dataset.immersive === 'true') {
        const SCROLLED = 'is-scrolled';
        const onScroll = () => {
          if (window.scrollY > 64) header.classList.add(SCROLLED);
          else header.classList.remove(SCROLLED);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>

    <style>
      [data-site-header].is-scrolled {
        background-color: oklch(0.13 0.005 60 / 0.88);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom-color: var(--color-border);
      }
    </style>
  </body>
</html>
