---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, type I18nKey, t } from '@/i18n/t';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const entries = await getCollection('faq');
const categories: ReadonlyArray<{ id: string; titleKey: I18nKey }> = [
  { id: 'booking', titleKey: 'faq.cat.booking' },
  { id: 'payment', titleKey: 'faq.cat.payment' },
  { id: 'cancel', titleKey: 'faq.cat.cancel' },
  { id: 'service', titleKey: 'faq.cat.service' },
  { id: 'vehicle', titleKey: 'faq.cat.vehicle' },
];
const grouped = categories.map((c) => ({
  ...c,
  items: entries
    .filter((e) => e.data.category === c.id)
    .sort((a, b) => a.data.order - b.data.order),
}));
---
<BaseLayout locale={locale} title={t(locale, 'faq.title')}>
  <Section spacing="tight">
    <Container size="wide" class="flex flex-col gap-6">
      <p class="caption">{locale === 'zh' ? '常见问题' : 'Frequently asked'}</p>
      <h1 class="font-display text-4xl sm:text-6xl max-w-3xl">{t(locale, 'faq.title')}</h1>
      <p class="text-text-muted max-w-xl leading-relaxed">
        {locale === 'zh'
          ? '若以下未能解答你的疑问,请通过 LINE / WeChat / 邮件直接联系我们。'
          : '以下で解決しないご質問は、LINE / WeChat / メールにて直接お問合せください。'}
      </p>
    </Container>
  </Section>

  <Section spacing="tight">
    <Container size="wide" class="flex flex-col gap-20">
      {grouped.map((g, gi) => g.items.length > 0 && (
        <section class="grid grid-cols-12 gap-6 sm:gap-12">
          <header class="col-span-12 md:col-span-3 flex flex-col gap-2 md:sticky md:top-28 self-start">
            <span class="ordinal text-text-muted text-sm tabular">
              {String(gi + 1).padStart(2, '0')}
            </span>
            <h2 class="font-display text-2xl sm:text-3xl text-text">{t(locale, g.titleKey)}</h2>
          </header>
          <ul class="col-span-12 md:col-span-9 flex flex-col">
            {g.items.map((entry) => (
              <li class="border-t border-border last:border-b">
                <details class="group">
                  <summary class="list-none cursor-pointer flex items-start justify-between gap-6 py-5 hover:text-gold">
                    <span class="font-display text-base sm:text-lg text-text group-hover:text-gold">
                      {entry.data.question[locale]}
                    </span>
                    <span
                      aria-hidden="true"
                      class="flex-shrink-0 text-text-muted group-open:rotate-45 transition-transform text-xl leading-none mt-1"
                    >+</span>
                  </summary>
                  <p class="text-text-muted text-sm sm:text-base leading-relaxed pb-6 pe-12 max-w-2xl">
                    {entry.data.answer[locale]}
                  </p>
                </details>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </Container>
  </Section>
</BaseLayout>
