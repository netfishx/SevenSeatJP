---
import PackageCard from '@/components/route/PackageCard.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, t } from '@/i18n/t';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const inquiryHref = locale === 'zh' ? '/zh/inquiry' : '/inquiry';

const all = await getCollection('packages');
const charterPkgs = all
  .filter((p) => p.data.type === 'charter')
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  locale={locale}
  title={t(locale, 'charter.title')}
  description={t(locale, 'charter.lead')}
>
  <Section>
    <Container class="flex flex-col gap-8">
      <header class="flex flex-col gap-4">
        <h1 class="text-4xl text-gold font-display">{t(locale, 'charter.title')}</h1>
        <p class="text-text-muted text-lg leading-relaxed max-w-3xl">
          {t(locale, 'charter.lead')}
        </p>
      </header>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {charterPkgs.map((p) => <PackageCard entry={p} locale={locale} />)}
      </div>
      <div class="flex justify-center pt-4">
        <Button href={inquiryHref} variant="primary">{t(locale, 'cta.inquire')}</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>
