---
import airportImg from '@/assets/photos/airport-hero.jpg';
import PriceTable from '@/components/route/PriceTable.astro';
import RouteHero from '@/components/route/RouteHero.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, t } from '@/i18n/t';
import { photoCredits } from '@/lib/credits';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const inquiryHref = locale === 'zh' ? '/zh/inquiry' : '/inquiry';
const alt = photoCredits.find((c) => c.file === 'airport-hero.jpg')?.alt[locale] ?? '';

const all = await getCollection('routes');
const airportRoutes = all
  .filter((r) => r.data.category === 'airport')
  .sort((a, b) => a.data.order - b.data.order);

const titleJa = { primary: '空港送迎', secondary: '深夜便も、家族連れも。' };
const titleZh = { primary: '空港接送', secondary: '夜班机, 全家行李, 一手安排。' };
const sublineJa = '成田・羽田・関西国際空港から東京 / 大阪 / 京都への定額送迎。フライト遅延時の無料待機・深夜対応。';
const sublineZh = '从成田、羽田、关西国际机场直达东京 / 大阪 / 京都的定额接送。航班延误免费等候，深夜亦可对应。';
---
<BaseLayout
  locale={locale}
  title={t(locale, 'airport.title')}
  description={t(locale, 'airport.lead')}
  immersiveHeader
>
  <RouteHero
    image={airportImg}
    alt={alt}
    eyebrow={locale === 'zh' ? '空港送迎 / Airport' : 'Airport / 空港送迎'}
    title={locale === 'ja' ? titleJa : titleZh}
    srOnlyTitle={t(locale, 'airport.title')}
    subline={locale === 'ja' ? sublineJa : sublineZh}
    family={locale === 'ja' ? 'display-jp' : 'display'}
  />

  <Section>
    <Container size="wide" class="grid grid-cols-12 gap-6 sm:gap-12">
      <p class="col-span-12 md:col-span-2 caption md:pt-2">
        {locale === 'zh' ? '说明' : 'Notes'}
      </p>
      <div class="col-span-12 md:col-span-7 flex flex-col gap-5 text-text">
        <p class="font-display text-xl sm:text-2xl leading-[1.5]">
          {locale === 'zh'
            ? '到达大厅举牌迎接、行李帮你抬上车、车上 Wi-Fi 与饮用水免费供应。'
            : '到着ロビーでネームボードをお持ちしてお出迎え、お荷物は車載まで、車内 Wi-Fi と水もご用意しています。'}
        </p>
        <p class="text-text-muted leading-relaxed">
          {locale === 'zh'
            ? '所有区段为定额制，含车辆、燃油、过路费、停车费、消费税。航班延误、深夜抵达均按原价对应，无附加费。'
            : '全区間定額。車両・燃料・高速・駐車・消費税込み。フライト遅延・深夜便ともに追加料金なしで対応します。'}
        </p>
      </div>
      <ul class="col-span-12 md:col-span-3 flex flex-col gap-3 text-sm border-y border-border py-5">
        <li class="flex justify-between"><span class="text-text-muted">{locale === 'zh' ? '车型' : '車両'}</span><span class="text-text">Alphard / Vellfire / Hiace</span></li>
        <li class="flex justify-between"><span class="text-text-muted">{locale === 'zh' ? '人数' : '乗車'}</span><span class="text-text tabular">~ 9</span></li>
        <li class="flex justify-between"><span class="text-text-muted">{locale === 'zh' ? '行李' : '荷物'}</span><span class="text-text tabular">~ 6</span></li>
      </ul>
    </Container>
  </Section>

  <Section spacing="tight">
    <Container size="wide" class="flex flex-col gap-8">
      <header class="flex items-end justify-between gap-4 border-b border-border-strong pb-4">
        <h2 class="font-display text-2xl sm:text-3xl">
          {locale === 'zh' ? '料金一览' : '料金一覧'}
        </h2>
        <p class="caption">{locale === 'zh' ? '消费税 · 全区段定额' : 'incl. tax · all-in'}</p>
      </header>
      <PriceTable routes={airportRoutes} locale={locale} />
    </Container>
  </Section>

  <Section spacing="loose">
    <Container size="wide" class="flex flex-col items-start gap-8">
      <p class="caption">{locale === 'zh' ? '预约' : 'Reserve'}</p>
      <h2 class="font-display text-3xl sm:text-5xl max-w-3xl">
        {locale === 'zh' ? '把航班号告诉我们，剩下的交给司机。' : 'フライト番号を送るだけ。残りはドライバーにお任せください。'}
      </h2>
      <Button href={inquiryHref} variant="solid">{t(locale, 'cta.inquire')}</Button>
    </Container>
  </Section>
</BaseLayout>
