---
import vehiclesImg from '@/assets/photos/vehicles-hero.jpg';
import RouteHero from '@/components/route/RouteHero.astro';
import VehicleCard from '@/components/route/VehicleCard.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, t } from '@/i18n/t';
import { photoCredits } from '@/lib/credits';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const inquiryHref = locale === 'zh' ? '/zh/inquiry' : '/inquiry';
const alt = photoCredits.find((c) => c.file === 'vehicles-hero.jpg')?.alt[locale] ?? '';

const all = await getCollection('vehicles');
const sorted = all.slice().sort((a, b) => a.data.order - b.data.order);

const titleJa = { primary: '車両ラインナップ。', secondary: '三台、ひとつの心遣い。' };
const titleZh = { primary: '车辆阵容。', secondary: '三车一心,贴身护航。' };
const sublineJa = '3 車種から、ご利用人数・荷物量・ご予算でお選びいただけます。すべて社内整備、定期検査済み。';
const sublineZh = '三款车型,按人数、行李量、预算自选。全部内部维护,定期检验。';
---
<BaseLayout
  locale={locale}
  title={t(locale, 'vehicles.title')}
  description={t(locale, 'vehicles.lead')}
  immersiveHeader
>
  <RouteHero
    image={vehiclesImg}
    alt={alt}
    eyebrow={locale === 'zh' ? '车辆 / Vehicles' : 'Vehicles / 車両'}
    title={locale === 'ja' ? titleJa : titleZh}
    srOnlyTitle={t(locale, 'vehicles.title')}
    subline={locale === 'ja' ? sublineJa : sublineZh}
    family={locale === 'ja' ? 'display-jp' : 'display'}
  />

  <Section>
    <Container size="wide" class="flex flex-col">
      {sorted.map((v, i) => <VehicleCard entry={v} locale={locale} index={i} />)}
    </Container>
  </Section>

  <Section spacing="loose">
    <Container size="wide" class="flex flex-col items-start gap-8">
      <p class="caption">{locale === 'zh' ? '咨询' : 'Inquire'}</p>
      <h2 class="font-display text-3xl sm:text-5xl max-w-3xl">
        {locale === 'zh' ? '不确定该选哪辆?把人数和行李告诉我们。' : '車種にお迷いなら、人数とお荷物をお知らせください。'}
      </h2>
      <Button href={inquiryHref} variant="solid">{t(locale, 'cta.inquire')}</Button>
    </Container>
  </Section>
</BaseLayout>
