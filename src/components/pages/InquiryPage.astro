---
import InquiryForm from '@/components/inquiry/InquiryForm.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const privacyHref = locale === 'zh' ? '/zh/legal/privacy' : '/legal/privacy';
---
<BaseLayout
  locale={locale}
  title={t(locale, 'inquiry.title')}
  description={t(locale, 'inquiry.lead')}
>
  <Section spacing="tight">
    <Container size="wide" class="grid grid-cols-12 gap-6 sm:gap-12">
      <header class="col-span-12 md:col-span-4 flex flex-col gap-5 md:sticky md:top-28 self-start">
        <p class="caption">{locale === 'zh' ? '咨询' : 'Inquiry'}</p>
        <h1 class="font-display text-3xl sm:text-5xl leading-[1.1]">
          <span class="sr-only">{t(locale, 'inquiry.title')}</span>
          <span aria-hidden="true">{locale === 'zh' ? '把行程' : 'ご旅程を'}</span><br />
          <span aria-hidden="true" class="text-gold">{locale === 'zh' ? '告诉我们。' : 'お送りください。'}</span>
        </h1>
        <p class="text-text-muted leading-relaxed text-sm sm:text-base">
          {t(locale, 'inquiry.lead')}
        </p>
        <div class="flex flex-col gap-2 text-sm border-t border-border pt-5">
          <p class="caption">{locale === 'zh' ? '其他联系方式' : 'その他の連絡先'}</p>
          <p class="text-text">LINE · <span class="text-text-muted">@sevenseatjp</span></p>
          <p class="text-text">WeChat · <span class="text-text-muted">sevenseatjp</span></p>
          <p class="text-text">Mail · <span class="text-text-muted">contact@sevenseatjp.com</span></p>
        </div>
      </header>

      <div class="col-span-12 md:col-span-8 flex flex-col gap-6">
        <InquiryForm locale={locale} />

        <p class="text-xs text-text-muted leading-relaxed">
          {t(locale, 'inquiry.privacy.note')}
          <a href={privacyHref} class="text-text underline underline-offset-4 hover:text-gold">
            {t(locale, 'inquiry.privacy.link')}
          </a>
          {t(locale, 'inquiry.privacy.note.after')}
        </p>

        <noscript>
          <div class="border border-border p-6 flex flex-col gap-3">
            <h2 class="font-display text-text">{t(locale, 'inquiry.noscript.heading')}</h2>
            <ul class="flex flex-col gap-1 text-sm text-text-muted">
              <li>{t(locale, 'inquiry.fallback.line')}</li>
              <li>{t(locale, 'inquiry.fallback.wechat')}</li>
              <li>{t(locale, 'inquiry.fallback.email')}</li>
            </ul>
          </div>
        </noscript>
      </div>
    </Container>
  </Section>
</BaseLayout>
