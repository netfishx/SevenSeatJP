---
import rentalImg from '@/assets/photos/rental-hero.jpg';
import PackageCard from '@/components/route/PackageCard.astro';
import RouteHero from '@/components/route/RouteHero.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, t } from '@/i18n/t';
import { photoCredits } from '@/lib/credits';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const inquiryHref = locale === 'zh' ? '/zh/inquiry' : '/inquiry';
const alt = photoCredits.find((c) => c.file === 'rental-hero.jpg')?.alt[locale] ?? '';

const all = await getCollection('packages');
const rentalPkgs = all
  .filter((p) => p.data.type === 'rental')
  .sort((a, b) => a.data.order - b.data.order);

const titleJa = { primary: 'ご自身で運転、', secondary: 'ゆっくりと。' };
const titleZh = { primary: '亲自驾驶,', secondary: '慢慢前行。' };
const sublineJa = '国際運転免許または公式日本語翻訳をお持ちのお客様向け。富士山周辺など人気エリアの 1〜2 日プラン。';
const sublineZh = '面向持国际驾照或日本官方译本的客人。富士山周边等热门区域,提供 1–2 日方案。';
---
<BaseLayout
  locale={locale}
  title={t(locale, 'rental.title')}
  description={t(locale, 'rental.lead')}
  immersiveHeader
>
  <RouteHero
    image={rentalImg}
    alt={alt}
    eyebrow={locale === 'zh' ? '自驾レンタル / Rental' : 'Rental / 自家用'}
    title={locale === 'ja' ? titleJa : titleZh}
    srOnlyTitle={t(locale, 'rental.title')}
    subline={locale === 'ja' ? sublineJa : sublineZh}
    family={locale === 'ja' ? 'display-jp' : 'display'}
  />

  <Section>
    <Container size="wide" class="grid grid-cols-12 gap-6 sm:gap-12">
      <p class="col-span-12 md:col-span-2 caption md:pt-2">
        {locale === 'zh' ? '所需文件' : '必要書類'}
      </p>
      <ul class="col-span-12 md:col-span-7 flex flex-col text-text">
        {[
          { ja: '国際運転免許証 (IDP) — 中国本土の方は要事前申請', zh: '国际驾照 (IDP) — 中国大陆客人需提前申请' },
          { ja: 'または日本領事館発行の公式日本語翻訳', zh: '或日本领事馆出具的官方日文翻译' },
          { ja: 'パスポート原本', zh: '护照原件' },
          { ja: 'クレジットカード (保証金用)', zh: '信用卡 (押金用)' },
        ].map((step, i) => (
          <li class="grid grid-cols-12 gap-3 py-5 border-t border-border last:border-b items-baseline">
            <span class="ordinal col-span-2 text-xl text-text-muted tabular">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="col-span-10 leading-relaxed">{locale === 'zh' ? step.zh : step.ja}</span>
          </li>
        ))}
      </ul>
      <div class="col-span-12 md:col-span-3 flex flex-col gap-3 text-sm border-y border-border py-5">
        <p><span class="text-text-muted">{locale === 'zh' ? '保险' : '保険'}</span> · <span class="text-text">{locale === 'zh' ? '全包' : 'フル'}</span></p>
        <p><span class="text-text-muted">ETC</span> · <span class="text-text">{locale === 'zh' ? '已配' : '装備済'}</span></p>
        <p><span class="text-text-muted">GPS</span> · <span class="text-text">{locale === 'zh' ? '中文导航' : '中国語'}</span></p>
      </div>
    </Container>
  </Section>

  <Section spacing="tight">
    <Container size="wide" class="flex flex-col gap-2">
      <header class="flex items-end justify-between gap-4 border-b border-border-strong pb-4 mb-4">
        <h2 class="font-display text-2xl sm:text-3xl">
          {locale === 'zh' ? '套餐一览' : 'プランラインナップ'}
        </h2>
        <p class="caption">{locale === 'zh' ? '保险·ETC·GPS 全含' : 'incl. insurance · ETC · GPS'}</p>
      </header>
      {rentalPkgs.map((p) => <PackageCard entry={p} locale={locale} />)}
    </Container>
  </Section>

  <Section spacing="loose">
    <Container size="wide" class="flex flex-col items-start gap-8">
      <p class="caption">{locale === 'zh' ? '预约' : 'Reserve'}</p>
      <h2 class="font-display text-3xl sm:text-5xl max-w-3xl">
        {locale === 'zh' ? '把出行日期和驾照信息发来,我们核对后回复。' : 'ご旅行日と免許の有無をお知らせください。確認次第ご返信します。'}
      </h2>
      <Button href={inquiryHref} variant="solid">{t(locale, 'cta.inquire')}</Button>
    </Container>
  </Section>
</BaseLayout>
