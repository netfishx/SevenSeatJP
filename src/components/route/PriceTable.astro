---
import { type Locale, t } from '@/i18n/t';
import { getEntries } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  routes: CollectionEntry<'routes'>[];
  locale: Locale;
}
const { routes, locale } = Astro.props;
const yen = new Intl.NumberFormat('ja-JP');

interface Row {
  from: string;
  to: string;
  duration: number;
  vehicleName: string;
  jpy: number;
  includes: string;
  notes?: string;
}

const rows: Row[] = [];
for (const route of routes) {
  const vehicles = await getEntries(route.data.fares.map((f) => f.vehicle));
  const vehicleMap = new Map(vehicles.map((v) => [v.id, v.data.name[locale]]));
  for (const fare of route.data.fares) {
    rows.push({
      from: route.data.from[locale],
      to: route.data.to[locale],
      duration: route.data.durationMin,
      vehicleName: vehicleMap.get(fare.vehicle.id) ?? fare.vehicle.id,
      jpy: fare.jpy,
      includes: fare.includes[locale],
      notes: fare.notes?.[locale],
    });
  }
}
---
<div class="w-full overflow-x-auto">
  <table class="w-full border-collapse tabular text-sm">
    <thead>
      <tr class="border-b border-border-strong text-text-deep text-xs">
        <th class="text-start font-normal py-3 pe-4">{t(locale, 'price.col.route')}</th>
        <th class="text-start font-normal py-3 pe-4 whitespace-nowrap">{t(locale, 'price.col.duration')}</th>
        <th class="text-start font-normal py-3 pe-4 whitespace-nowrap">{t(locale, 'price.col.vehicle')}</th>
        <th class="text-end font-normal py-3 pe-4 whitespace-nowrap">{t(locale, 'price.col.price')}</th>
        <th class="text-start font-normal py-3 pe-4">{t(locale, 'price.col.includes')}</th>
        <th class="text-start font-normal py-3">{t(locale, 'price.col.notes')}</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((r) => (
          <tr class="border-b border-border align-top">
            <td class="py-5 pe-4 font-display text-base sm:text-lg text-text">
              <span class="block">{r.from}</span>
              <span class="text-text-deep">↓</span>
              <span class="block">{r.to}</span>
            </td>
            <td class="py-5 pe-4 text-text-muted whitespace-nowrap">
              {r.duration} <span class="text-text-deep">{t(locale, 'price.duration.minutes')}</span>
            </td>
            <td class="py-5 pe-4 text-text whitespace-nowrap">{r.vehicleName}</td>
            <td class="py-5 pe-4 text-end whitespace-nowrap">
              <span class="text-text-deep">¥</span><span class="font-display text-lg">{yen.format(r.jpy)}</span>
            </td>
            <td class="py-5 pe-4 text-text-muted text-xs leading-relaxed">{r.includes}</td>
            <td class="py-5 text-text-muted text-xs leading-relaxed">{r.notes ?? ''}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
