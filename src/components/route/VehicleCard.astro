---
import Card from '@/components/ui/Card.astro';
import { type Locale, t } from '@/i18n/t';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  entry: CollectionEntry<'vehicles'>;
  locale: Locale;
}
const { entry, locale } = Astro.props;
const photo = entry.data.photos[0];
---
<Card class="flex flex-col gap-4 p-0 overflow-hidden">
  {
    photo && (
      <Image
        src={photo}
        alt={entry.data.name[locale]}
        width={640}
        height={360}
        sizes="(min-width: 768px) 33vw, 100vw"
        class="w-full aspect-[16/9] object-cover"
      />
    )
  }
  <div class="flex flex-col gap-3 p-6 pt-0">
    <h3 class="text-xl font-display text-gold">{entry.data.name[locale]}</h3>
    <dl class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-text-muted">
      <div class="flex flex-col">
        <dt class="text-xs uppercase tracking-wider">{t(locale, 'vehicles.seat')}</dt>
        <dd class="text-text font-display">{entry.data.seatCount}</dd>
      </div>
      <div class="flex flex-col">
        <dt class="text-xs uppercase tracking-wider">{t(locale, 'vehicles.luggage')}</dt>
        <dd class="text-text font-display">{entry.data.luggageCount}</dd>
      </div>
    </dl>
    <ul class="flex flex-col gap-1 text-sm text-text-muted">
      {entry.data.features.map((f) => <li>· {f[locale]}</li>)}
    </ul>
  </div>
</Card>
