---
import { type Locale, t } from '@/i18n/t';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  entry: CollectionEntry<'vehicles'>;
  locale: Locale;
  /** Index in the vehicle list — drives the ordinal label */
  index?: number;
}
const { entry, locale, index = 0 } = Astro.props;
const photo = entry.data.photos[0];
const isOdd = index % 2 === 1;
---
<article
  class:list={[
    'group grid grid-cols-1 lg:grid-cols-12 gap-6 sm:gap-12 items-center py-12 sm:py-20 border-t border-border first:border-t-0',
  ]}
>
  <div class:list={[
    'lg:col-span-7 relative aspect-[5/3] overflow-hidden bg-surface',
    isOdd && 'lg:col-start-6',
  ]}>
    {photo ? (
      <Image
        src={photo}
        alt={entry.data.name[locale]}
        widths={[400, 800, 1200]}
        sizes="(min-width: 1024px) 58vw, 100vw"
        quality={78}
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center text-text-deep caption">
        photography pending
      </div>
    )}
  </div>

  <div class:list={[
    'lg:col-span-5 flex flex-col gap-6',
    isOdd && 'lg:row-start-1 lg:col-start-1',
  ]}>
    <span class="ordinal text-text-muted text-base tabular">
      {String(index + 1).padStart(2, '0')} / 0{entry.data.order ?? 0}
    </span>
    <h3 class="font-display text-3xl sm:text-4xl text-text">{entry.data.name[locale]}</h3>

    <dl class="grid grid-cols-2 gap-x-6 gap-y-4 border-y border-border py-5">
      <div class="flex flex-col gap-1">
        <dt class="caption">{t(locale, 'vehicles.seat')}</dt>
        <dd class="font-display text-2xl text-text tabular">{entry.data.seatCount}</dd>
      </div>
      <div class="flex flex-col gap-1">
        <dt class="caption">{t(locale, 'vehicles.luggage')}</dt>
        <dd class="font-display text-2xl text-text tabular">{entry.data.luggageCount}</dd>
      </div>
    </dl>

    <ul class="flex flex-col gap-2 text-sm text-text-muted leading-relaxed">
      {entry.data.features.map((f) => (
        <li class="flex gap-3">
          <span aria-hidden="true" class="text-gold mt-1.5 flex-shrink-0">·</span>
          <span>{f[locale]}</span>
        </li>
      ))}
    </ul>
  </div>
</article>
