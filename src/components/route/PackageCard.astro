---
import { type Locale, t } from '@/i18n/t';
import { getEntries } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'packages'>;
  locale: Locale;
}
const { entry, locale } = Astro.props;
const yen = new Intl.NumberFormat('ja-JP');

const allFareVehicles = entry.data.durations.flatMap((d) => d.fares.map((f) => f.vehicle));
const uniqueVehicleRefs = Array.from(new Map(allFareVehicles.map((v) => [v.id, v])).values());
const vehicles = await getEntries(uniqueVehicleRefs);
const vehicleMap = new Map(vehicles.map((v) => [v.id, v.data.name[locale]]));
---
<article class="flex flex-col gap-8 py-10 border-t border-border first:border-t-0">
  <header class="flex flex-col gap-2">
    <h3 class="font-display text-2xl sm:text-3xl text-text">{entry.data.title[locale]}</h3>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <div class="md:col-span-7 flex flex-col">
      {entry.data.durations.map((d, di) => (
        <div class="grid grid-cols-12 gap-3 py-5 border-b border-border last:border-b-0 items-baseline">
          <span class="ordinal col-span-2 text-xl text-text-muted tabular">
            {String(di + 1).padStart(2, '0')}
          </span>
          <span class="col-span-4 font-display text-base sm:text-lg text-text">
            {d.label[locale]}
          </span>
          <ul class="col-span-6 flex flex-col gap-1.5 text-sm">
            {d.fares.map((f) => (
              <li class="flex justify-between gap-3">
                <span class="text-text-muted">{vehicleMap.get(f.vehicle.id) ?? f.vehicle.id}</span>
                <span class="tabular text-text">
                  <span class="text-text-deep">¥</span><span class="font-display">{yen.format(f.jpy)}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="md:col-span-5 flex flex-col gap-6">
      <div class="flex flex-col gap-3">
        <p class="caption">{t(locale, 'package.inclusions')}</p>
        <ul class="flex flex-col gap-2 text-sm text-text-muted leading-relaxed">
          {entry.data.inclusions.map((inc) => (
            <li class="flex gap-3">
              <span aria-hidden="true" class="text-text-deep mt-1.5 flex-shrink-0">·</span>
              <span>{inc[locale]}</span>
            </li>
          ))}
        </ul>
      </div>

      {entry.data.excludeRegions && (
        <div class="flex flex-col gap-2 pt-4 border-t border-border">
          <p class="caption">{t(locale, 'package.excludes')}</p>
          <p class="text-xs text-text-muted leading-relaxed">{entry.data.excludeRegions[locale]}</p>
        </div>
      )}
      {entry.data.notes && (
        <p class="text-xs text-text-deep leading-relaxed border-t border-border pt-4">
          {entry.data.notes[locale]}
        </p>
      )}
    </div>
  </div>
</article>
