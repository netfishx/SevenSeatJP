---
/**
 * In the Aman lacquer system, cards are rarely the right answer — most
 * surfaces sit directly on the ink ground with hairline rules. This
 * primitive remains so legacy callers compile and so the few real card
 * cases (gallery thumbs, vehicle stub frames) have a quiet container.
 */
interface Props {
  padding?: 'default' | 'none';
  class?: string;
}
const { padding = 'default', class: extra = '' } = Astro.props;
const padCls = padding === 'none' ? '' : 'p-6 sm:p-8';
---
<div
  class:list={[
    'bg-surface border border-border',
    padCls,
    extra,
  ]}
><slot /></div>
