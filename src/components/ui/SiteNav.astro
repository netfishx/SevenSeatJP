---
import { type I18nKey, type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
  variant?: 'header' | 'footer';
}
const { locale, variant = 'header' } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';

const links: ReadonlyArray<{ slug: string; key: I18nKey }> = [
  { slug: '', key: 'nav.home' },
  { slug: '/airport-transfer', key: 'nav.airport' },
  { slug: '/charter', key: 'nav.charter' },
  { slug: '/ski-hakuba', key: 'nav.ski' },
  { slug: '/rental', key: 'nav.rental' },
  { slug: '/vehicles', key: 'nav.vehicles' },
  { slug: '/pricing', key: 'nav.pricing' },
  { slug: '/about', key: 'nav.about' },
  { slug: '/faq', key: 'nav.faq' },
  { slug: '/inquiry', key: 'nav.inquiry' },
];

const currentPath = Astro.url.pathname.replace(/^\/zh\//, '/').replace(/^\/zh$/, '/');
---
{
  variant === 'header' && (
    <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
      {links.map((l) => {
        const href = `${prefix}${l.slug || '/'}`;
        const isActive = (l.slug || '/') === (currentPath || '/');
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'inline-flex items-center min-h-11 px-3 text-sm transition-colors',
              isActive ? 'text-gold' : 'text-text hover:text-gold focus-visible:text-gold',
            ]}
          >
            {t(locale, l.key)}
          </a>
        );
      })}
    </nav>
  )
}

{
  variant === 'footer' && (
    <nav aria-label="Footer" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2">
      {links.map((l) => {
        const href = `${prefix}${l.slug || '/'}`;
        return (
          <a
            href={href}
            class="inline-flex items-center min-h-11 text-sm text-text-muted hover:text-gold focus-visible:text-gold"
          >
            {t(locale, l.key)}
          </a>
        );
      })}
    </nav>
  )
}
