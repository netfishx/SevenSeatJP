---
import { type I18nKey, type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
  variant?: 'header' | 'footer';
}
const { locale, variant = 'header' } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';

const links: ReadonlyArray<{ slug: string; key: I18nKey }> = [
  { slug: '/vehicles', key: 'nav.vehicles' },
  { slug: '/about', key: 'nav.about' },
  { slug: '/faq', key: 'nav.faq' },
  { slug: '/inquiry', key: 'nav.inquiry' },
];

const currentPath = Astro.url.pathname.replace(/^\/zh\//, '/').replace(/^\/zh$/, '/');
---
{
  variant === 'header' && (
    <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
      {links.map((l) => {
        const href = `${prefix}${l.slug}`;
        const isActive = l.slug === currentPath;
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'inline-flex items-center min-h-11 px-3 text-[0.78rem] tracking-[0.15em] uppercase transition-colors',
              isActive ? 'text-text' : 'text-text-muted hover:text-text focus-visible:text-text',
            ]}
          >
            {t(locale, l.key)}
          </a>
        );
      })}
    </nav>
  )
}

{
  variant === 'footer' && (
    <ul class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-3">
      {links.map((l) => {
        const href = `${prefix}${l.slug}`;
        return (
          <li>
            <a
              href={href}
              class="inline-flex items-center min-h-11 text-sm text-text-muted hover:text-text"
            >{t(locale, l.key)}</a>
          </li>
        );
      })}
    </ul>
  )
}
