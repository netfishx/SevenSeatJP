---
import heroImg from '@/assets/photos/home-hero.jpg';
import Button from '@/components/ui/Button.astro';
import { type Locale, t } from '@/i18n/t';
import { photoCredits } from '@/lib/credits';
import { Image } from 'astro:assets';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const inquiryHref = locale === 'zh' ? '/zh/inquiry' : '/inquiry';
const alt = photoCredits.find((c) => c.file === 'home-hero.jpg')?.alt[locale] ?? '';

const eyebrow = locale === 'zh' ? '私享专车 · 双语司机' : 'Private hire · Bilingual driver';
const headlineJa1 = '七人乗りで、';
const headlineJa2 = 'ひとつの旅を。';
const headlineZh1 = '七座一程,';
const headlineZh2 = '一段静谧之行。';
const subline =
  locale === 'zh'
    ? '从成田到白马，从京都到富士，由会说中文的日本本地司机贴身护航。'
    : '成田から白馬、京都から富士まで——中国語が話せる日本人ドライバーがお供します。';
---
<section class="relative isolate h-[100svh] min-h-[600px] flex flex-col overflow-hidden">
  <Image
    src={heroImg}
    alt={alt}
    widths={[640, 1024, 1600, 2400]}
    sizes="100vw"
    quality={80}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover -z-10"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-gradient-to-b from-bg/40 via-bg/10 to-bg"
  ></div>
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-gradient-to-r from-bg/70 via-bg/20 to-transparent"
  ></div>

  <div class="flex-1 flex justify-center">
    <div class="w-full max-w-7xl px-5 sm:px-8 pt-28 sm:pt-40 pb-12 sm:pb-16 flex flex-col justify-end gap-6 sm:gap-8">
      <p class="caption text-text">{eyebrow}</p>
      {locale === 'ja' ? (
        <h1 class="font-display-jp text-[clamp(2rem,1.2rem+3vw,6rem)] leading-[1.1] tracking-tight max-w-4xl break-words">
          <span class="sr-only">{t(locale, 'home.title')}</span>
          <span aria-hidden="true" class="block">{headlineJa1}</span>
          <span aria-hidden="true" class="block text-gold">{headlineJa2}</span>
        </h1>
      ) : (
        <h1 class="font-display text-[clamp(2rem,1.2rem+3vw,6rem)] leading-[1.1] tracking-tight max-w-4xl break-words">
          <span class="sr-only">{t(locale, 'home.title')}</span>
          <span aria-hidden="true" class="block">{headlineZh1}</span>
          <span aria-hidden="true" class="block text-gold">{headlineZh2}</span>
        </h1>
      )}
      <p class="max-w-xl text-sm sm:text-lg leading-relaxed text-text-muted">
        {subline}
      </p>
      <Button href={inquiryHref} variant="link">
        {t(locale, 'home.cta')}
      </Button>
    </div>
  </div>

</section>
