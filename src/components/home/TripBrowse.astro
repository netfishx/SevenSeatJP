---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';

const routes = await getCollection('routes');
const packages = await getCollection('packages');
const yen = new Intl.NumberFormat('ja-JP');

interface TripItem {
  slug: string;
  title: string;
  duration: string;
  startingFrom: number;
  sortKey: number;
}

// Trips merge into one ordered list. Sort key combines a category-priority
// offset with the trip's own .order field so the airport routes (highest
// volume) lead, then full-day charter, ski (seasonal), self-drive rental.
const CATEGORY_PRIORITY = {
  airport: 0,
  charter: 100,
  ski: 200,
  rental: 300,
} as const;

function routeToTrip(r: CollectionEntry<'routes'>): TripItem {
  const minFare = Math.min(...r.data.fares.map((f) => f.jpy));
  return {
    slug: r.id,
    title: `${r.data.from[locale]} → ${r.data.to[locale]}`,
    duration: `${r.data.durationMin} ${locale === 'zh' ? '分' : '分'}`,
    startingFrom: minFare,
    sortKey: CATEGORY_PRIORITY[r.data.category] + r.data.order,
  };
}

function packageToTrip(p: CollectionEntry<'packages'>): TripItem {
  const allFares = p.data.durations.flatMap((d) => d.fares.map((f) => f.jpy));
  const minFare = Math.min(...allFares);
  const longest = p.data.durations.reduce((a, b) => (b.hours > a.hours ? b : a));
  return {
    slug: p.id,
    title: p.data.title[locale],
    duration: longest.label[locale],
    startingFrom: minFare,
    sortKey: CATEGORY_PRIORITY[p.data.type] + p.data.order,
  };
}

const trips: TripItem[] = [
  ...routes.map(routeToTrip),
  ...packages.map(packageToTrip),
].sort((a, b) => a.sortKey - b.sortKey);
---
<section class="flex justify-center">
  <div class="w-full max-w-7xl px-5 sm:px-8 py-16 sm:py-24 grid grid-cols-12 gap-6 sm:gap-12">
    <p class="caption col-span-12 md:col-span-2">{t(locale, 'trip.browse.heading')}</p>
    <ol class="col-span-12 md:col-span-10 flex flex-col">
      {trips.map((item, i) => (
        <li>
          <a
            href={`${prefix}/trip/${item.slug}`}
            class:list={[
              'group flex flex-col gap-2 sm:grid sm:grid-cols-12 sm:gap-4 sm:items-baseline py-5 sm:py-6 text-text hover:text-gold transition-colors min-h-11',
              i > 0 && 'border-t border-border',
            ]}
          >
            <div class="flex items-baseline gap-4 sm:contents">
              <span class="ordinal text-text-muted tabular text-sm w-8 sm:col-span-1 sm:w-auto">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="flex-1 sm:col-span-7 font-display text-xl sm:text-2xl group-hover:translate-x-1 transition-transform">
                {item.title}
              </span>
            </div>
            <div class="flex items-baseline gap-4 ps-12 sm:contents text-sm text-text-muted">
              <span class="tabular sm:col-span-2 sm:text-end">{item.duration}</span>
              <span class="tabular sm:col-span-2 sm:text-end">
                <span class="text-text-deep">¥</span><span>{yen.format(item.startingFrom)}〜</span>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>
