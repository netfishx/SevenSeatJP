---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';

const routes = await getCollection('routes');
const packages = await getCollection('packages');
const yen = new Intl.NumberFormat('ja-JP');

interface TripItem {
  slug: string;
  title: string;
  duration: string;
  startingFrom: number;
}

const airportRoutes = routes
  .filter((r) => r.data.category === 'airport')
  .sort((a, b) => a.data.order - b.data.order);
const skiRoutes = routes
  .filter((r) => r.data.category === 'ski')
  .sort((a, b) => a.data.order - b.data.order);
const charterPkgs = packages
  .filter((p) => p.data.type === 'charter')
  .sort((a, b) => a.data.order - b.data.order);
const rentalPkgs = packages
  .filter((p) => p.data.type === 'rental')
  .sort((a, b) => a.data.order - b.data.order);

function routeToTrip(r: CollectionEntry<'routes'>): TripItem {
  const minFare = Math.min(...r.data.fares.map((f) => f.jpy));
  return {
    slug: r.id,
    title: `${r.data.from[locale]} → ${r.data.to[locale]}`,
    duration: `${r.data.durationMin} ${locale === 'zh' ? '分' : '分'}`,
    startingFrom: minFare,
  };
}

function packageToTrip(p: CollectionEntry<'packages'>): TripItem {
  const allFares = p.data.durations.flatMap((d) => d.fares.map((f) => f.jpy));
  const minFare = Math.min(...allFares);
  const longest = p.data.durations.reduce((a, b) => (b.hours > a.hours ? b : a));
  return {
    slug: p.id,
    title: p.data.title[locale],
    duration: longest.label[locale],
    startingFrom: minFare,
  };
}

const groups = [
  {
    key: 'airport',
    label: t(locale, 'trip.browse.group.airport'),
    items: airportRoutes.map(routeToTrip),
  },
  {
    key: 'day',
    label: t(locale, 'trip.browse.group.day'),
    items: charterPkgs.map(packageToTrip),
  },
  {
    key: 'ski',
    label: t(locale, 'trip.browse.group.ski'),
    items: skiRoutes.map(routeToTrip),
  },
  {
    key: 'selfdrive',
    label: t(locale, 'trip.browse.group.selfdrive'),
    items: rentalPkgs.map(packageToTrip),
  },
];
---
<section class="flex justify-center">
  <div class="w-full max-w-7xl px-5 sm:px-8 py-16 sm:py-24 grid grid-cols-12 gap-6 sm:gap-12">
    <p class="caption col-span-12 md:col-span-2">{t(locale, 'trip.browse.heading')}</p>
    <div class="col-span-12 md:col-span-10 flex flex-col gap-14 sm:gap-20">
      {groups.map((group) => (
        <div class="flex flex-col gap-6 sm:gap-8">
          <h3 class="font-display text-2xl sm:text-3xl text-text">{group.label}</h3>
          <ol class="flex flex-col">
            {group.items.map((item, i) => (
              <li>
                <a
                  href={`${prefix}/trip/${item.slug}`}
                  class:list={[
                    'group grid grid-cols-12 gap-4 items-baseline py-5 sm:py-6 text-text hover:text-gold transition-colors min-h-11',
                    i > 0 && 'border-t border-border',
                  ]}
                >
                  <span class="col-span-1 ordinal text-text-muted tabular text-sm">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="col-span-11 sm:col-span-7 font-display text-xl sm:text-2xl group-hover:translate-x-1 transition-transform">
                    {item.title}
                  </span>
                  <span class="hidden sm:inline col-span-2 text-sm text-text-muted tabular text-end">
                    {item.duration}
                  </span>
                  <span class="hidden sm:inline col-span-2 text-sm tabular text-end">
                    <span class="text-text-deep">¥</span><span class="text-text-muted">{yen.format(item.startingFrom)}〜</span>
                  </span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </div>
</section>
