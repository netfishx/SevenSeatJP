---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import type { Locale } from '@/i18n/t';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

interface Metric {
  figure: string;
  label: { ja: string; zh: string };
}

const metrics: ReadonlyArray<Metric> = [
  { figure: '10y', label: { ja: '運営実績', zh: '运营年数' } },
  { figure: '500+', label: { ja: '年間送迎数', zh: '年送迎次数' } },
  { figure: '24h', label: { ja: '深夜対応', zh: '深夜对应' } },
  { figure: 'JA·中', label: { ja: '二言語ドライバー', zh: '双语司机' } },
];
---
<Section spacing="tight">
  <Container size="wide">
    <ul class="grid grid-cols-2 md:grid-cols-4 border-t border-border">
      {metrics.map((m) => (
        <li class="px-2 py-8 sm:py-12 border-b md:border-b-0 md:border-e border-border last:md:border-e-0 flex flex-col gap-3">
          <span class="ordinal text-5xl sm:text-6xl text-text">{m.figure}</span>
          <span class="caption text-text-muted">{m.label[locale]}</span>
        </li>
      ))}
    </ul>
  </Container>
</Section>
