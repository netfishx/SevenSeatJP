---
import airportImg from '@/assets/photos/airport-hero.jpg';
import charterImg from '@/assets/photos/charter-hero.jpg';
import rentalImg from '@/assets/photos/rental-hero.jpg';
import skiImg from '@/assets/photos/ski-hero.jpg';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import { type I18nKey, type Locale, t } from '@/i18n/t';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';

interface ServiceEntry {
  slug: string;
  titleKey: I18nKey;
  descKey: I18nKey;
  photo: ImageMetadata;
  /** EN supplementary label, kept untranslated for editorial rhythm. */
  enLabel: string;
}

const services: ReadonlyArray<ServiceEntry> = [
  { slug: 'airport-transfer', titleKey: 'service.airport.title', descKey: 'service.airport.desc', photo: airportImg, enLabel: 'Airport' },
  { slug: 'charter', titleKey: 'service.charter.title', descKey: 'service.charter.desc', photo: charterImg, enLabel: 'Charter' },
  { slug: 'ski-hakuba', titleKey: 'service.ski.title', descKey: 'service.ski.desc', photo: skiImg, enLabel: 'Hakuba' },
  { slug: 'rental', titleKey: 'service.rental.title', descKey: 'service.rental.desc', photo: rentalImg, enLabel: 'Rental' },
];
---
<Section id="services">
  <Container size="wide" class="flex flex-col gap-16 sm:gap-24">
    <header class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-6 border-b border-border pb-8">
      <div>
        <p class="caption mb-3">{locale === 'zh' ? '服务' : 'Services'} — 04</p>
        <h2 class="font-display text-3xl sm:text-5xl max-w-2xl">
          {locale === 'zh' ? '一手安排，覆盖你旅程的每一段' : '旅のすべての場面に、一手の手配を。'}
        </h2>
      </div>
      <p class="text-text-muted text-sm max-w-xs">
        {locale === 'zh'
          ? '空港送迎、市内チャーター、白马滑雪、自驾レンタル。四种方式覆盖出行所需。'
          : '空港送迎、市内チャーター、白馬スキー、自家用レンタル。四つの選択肢で旅をつなぎます。'}
      </p>
    </header>

    <ul class="flex flex-col">
      {services.map((s, i) => (
        <li class="border-t border-border last:border-b">
          <a
            data-service-card
            href={`${prefix}/${s.slug}`}
            class="group grid grid-cols-12 gap-4 sm:gap-8 py-10 sm:py-14 items-center hover:bg-surface/40 transition-colors"
          >
            <span class="ordinal col-span-2 sm:col-span-1 text-2xl sm:text-3xl text-text-muted group-hover:text-gold transition-colors">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="col-span-10 sm:col-span-5 flex flex-col gap-3">
              <p class="caption">{s.enLabel}</p>
              <h3 class="font-display text-2xl sm:text-4xl group-hover:translate-x-1 transition-transform">
                {t(locale, s.titleKey)}
              </h3>
              <p class="text-text-muted text-sm sm:text-base leading-relaxed max-w-md">
                {t(locale, s.descKey)}
              </p>
            </div>
            <div class="hidden sm:block col-span-6 relative aspect-[16/10] overflow-hidden">
              <Image
                src={s.photo}
                alt=""
                widths={[400, 800, 1200]}
                sizes="(min-width: 1024px) 50vw, 100vw"
                quality={78}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <span
                aria-hidden="true"
                class="absolute inset-0 bg-gradient-to-tr from-bg/40 to-transparent"
              ></span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </Container>
</Section>
