---
import { type Locale, t } from '@/i18n/t';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
const countryCodes = ['+81', '+86', '+852', '+853', '+886', '+1', '+44', '+65', '+82'] as const;
---
<form id="inquiry-form" novalidate class="flex flex-col gap-6 w-full">
  <div class="flex flex-col gap-2">
    <label for="serviceType" class="text-sm font-display text-text">
      {t(locale, 'inquiry.field.serviceType')}
      <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
    </label>
    <select
      id="serviceType"
      name="serviceType"
      required
      class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
    >
      <option value="airport">{t(locale, 'inquiry.serviceType.airport')}</option>
      <option value="charter">{t(locale, 'inquiry.serviceType.charter')}</option>
      <option value="ski">{t(locale, 'inquiry.serviceType.ski')}</option>
      <option value="rental">{t(locale, 'inquiry.serviceType.rental')}</option>
    </select>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="flex flex-col gap-2">
      <label for="from" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.from')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="text"
        id="from"
        name="from"
        required
        maxlength="200"
        placeholder={t(locale, 'inquiry.field.from.placeholder')}
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
    <div class="flex flex-col gap-2">
      <label for="to" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.to')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="text"
        id="to"
        name="to"
        required
        maxlength="200"
        placeholder={t(locale, 'inquiry.field.to.placeholder')}
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="flex flex-col gap-2">
      <label for="date" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.date')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="date"
        id="date"
        name="date"
        required
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
    <div class="flex flex-col gap-2">
      <label for="time" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.time')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="time"
        id="time"
        name="time"
        required
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
  </div>

  <div class="grid grid-cols-2 gap-6">
    <div class="flex flex-col gap-2">
      <label for="passengers" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.passengers')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="number"
        inputmode="numeric"
        id="passengers"
        name="passengers"
        required
        min="1"
        max="10"
        value="2"
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
    <div class="flex flex-col gap-2">
      <label for="luggage" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.luggage')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="number"
        inputmode="numeric"
        id="luggage"
        name="luggage"
        required
        min="0"
        max="15"
        value="2"
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
  </div>

  <div class="flex flex-col gap-2">
    <label for="notes" class="text-sm font-display text-text">{t(locale, 'inquiry.field.notes')}</label>
    <textarea
      id="notes"
      name="notes"
      rows="4"
      maxlength="2000"
      placeholder={t(locale, 'inquiry.field.notes.placeholder')}
      class="bg-surface border border-border rounded-[var(--radius-card)] px-3 py-2 text-text"
    ></textarea>
  </div>

  <div class="flex flex-col gap-2">
    <label for="name" class="text-sm font-display text-text">
      {t(locale, 'inquiry.field.name')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      maxlength="100"
      class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="email" class="text-sm font-display text-text">
      {t(locale, 'inquiry.field.email')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
    </label>
    <input
      type="email"
      inputmode="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="flex flex-col gap-2">
      <label for="lineId" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.lineId')}
      </label>
      <input
        type="text"
        id="lineId"
        name="lineId"
        maxlength="100"
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
    <div class="flex flex-col gap-2">
      <label for="wechat" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.wechat')}
      </label>
      <input
        type="text"
        id="wechat"
        name="wechat"
        maxlength="100"
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
  </div>

  <div class="grid grid-cols-[6rem_1fr] gap-3">
    <div class="flex flex-col gap-2">
      <label for="phoneCountryCode" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.phoneCountryCode')}
      </label>
      <select
        id="phoneCountryCode"
        name="phoneCountryCode"
        required
        class="bg-surface border border-border rounded-[var(--radius-card)] px-2 min-h-11 text-text"
      >
        {countryCodes.map((code) => <option value={code}>{code}</option>)}
      </select>
    </div>
    <div class="flex flex-col gap-2">
      <label for="phone" class="text-sm font-display text-text">
        {t(locale, 'inquiry.field.phone')} <span class="text-gold text-xs">· {t(locale, 'inquiry.required')}</span>
      </label>
      <input
        type="tel"
        inputmode="tel"
        id="phone"
        name="phone"
        required
        autocomplete="tel-national"
        minlength="4"
        maxlength="20"
        class="bg-surface border border-border rounded-[var(--radius-card)] px-3 min-h-11 text-text"
      />
    </div>
  </div>

  <div class="flex flex-col gap-3">
    <div
      class="cf-turnstile"
      data-sitekey={siteKey}
      data-size="flexible"
      data-theme="dark"
    ></div>
    <p
      id="inquiry-error"
      role="alert"
      aria-live="polite"
      class="text-sm text-red-400 min-h-5"
    ></p>
  </div>

  <button
    type="submit"
    class="inline-flex items-center justify-center min-h-11 px-6 rounded-[var(--radius-card)] font-display bg-gold text-bg hover:bg-gold-dark disabled:opacity-60"
  >
    <span data-submit-label>{t(locale, 'form.submit')}</span>
  </button>
</form>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  import '@/components/inquiry/inquiry-form.client';
</script>
